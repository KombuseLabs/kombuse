{
  "name": "kombuse-mono",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "tailwindcss": "^4.1.18",
    "turbo": "^2.8.1",
    "typescript": "5.9.2",
    "vitest": "^3.0.0",
    "web": "workspace:*"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.5",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
