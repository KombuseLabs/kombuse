{
  "name": "desktop",
  "version": "0.1.1",
  "private": true,
  "main": "dist/shell/main.mjs",
  "scripts": {
    "dev": "bun run build:shell && bun run rebuild && KOMBUSE_MODE=dev ELECTRON_RUN_AS_NODE= electron . ; bun run rebuild:node",
    "preview": "bun run build:shell && bun run build:package && bun run rebuild && KOMBUSE_MODE=preview ELECTRON_RUN_AS_NODE= electron . ; bun run rebuild:node",
    "build": "bun run build:shell",
    "build:shell": "esbuild src/shell/main.ts --bundle --platform=node --format=esm --external:electron --external:better-sqlite3 --banner:js=\"import{createRequire}from'module';const require=createRequire(import.meta.url);\" --outfile=dist/shell/main.mjs && esbuild src/shell/preload.ts --bundle --platform=node --format=cjs --external:electron --outfile=dist/shell/preload.cjs",
    "build:web": "bun run --filter web build",
    "build:package": "bun run build:web && bun run build/build-package.ts",
    "install-package": "bun run scripts/install-package.ts",
    "bundle:package": "bun run build:package && bun run scripts/bundle-package.ts",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "rebuild:node": "cd ../.. && npm rebuild better-sqlite3",
    "start": "ELECTRON_RUN_AS_NODE= electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@kombuse/persistence": "*",
    "@kombuse/types": "*",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^17.2.3",
    "server": "*",
    "tar": "^7.4.3"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@repo/eslint-config": "*",
    "@repo/typescript-config": "*",
    "@types/mime-types": "^3.0.1",
    "electron": "^40.0.0",
    "electron-builder": "^26.7.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.26.0",
    "mime-types": "^3.0.2",
    "typescript": "^5.9.0-beta"
  }
}
