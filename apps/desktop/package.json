{
  "name": "desktop",
  "version": "1.0.0-rc.21",
  "private": true,
  "type": "module",
  "main": "dist/shell/main.mjs",
  "scripts": {
    "dev": "bun run build:server && bun run build:shell && bun run rebuild && KOMBUSE_PORT=3331 KOMBUSE_MODE=dev ELECTRON_RUN_AS_NODE= electron .",
    "preview": "bun run build:shell && bun run build:package && bun run rebuild && KOMBUSE_MODE=preview ELECTRON_RUN_AS_NODE= electron .",
    "build": "bun run build:shell",
    "build:server": "bun run --cwd ../server build",
    "build:shell": "bun run build/build-shell.ts",
    "build:web": "bun run --filter web build",
    "build:package": "bun run build:server && bun run build:web && bun run build/build-package.ts",
    "install-package": "bun run scripts/install-package.ts",
    "bundle:package": "bun run build:package && bun run scripts/bundle-package.ts",
    "prepare:native-deps": "node scripts/ensure-local-native-deps.mjs",
    "rebuild": "bun run prepare:native-deps && node scripts/rebuild-desktop-better-sqlite3.mjs",
    "rebuild:node": "cd ../.. && npm rebuild better-sqlite3 --prefix packages/persistence",
    "start": "bun run prepare:native-deps && ELECTRON_RUN_AS_NODE= electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@kombuse/core": "*",
    "@kombuse/pkg": "*",
    "@kombuse/types": "*",
    "@sentry/electron": "^7.9.0",
    "@sentry/esbuild-plugin": "^5.1.1",
    "better-sqlite3": "^12.6.2",
    "bindings": "^1.5.0",
    "dotenv": "^17.2.3",
    "electron-updater": "6.8.3",
    "server": "*"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@repo/eslint-config": "*",
    "@repo/typescript-config": "*",
    "@types/mime-types": "^3.0.1",
    "electron": "40.3.0",
    "electron-builder": "^26.7.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.26.0",
    "mime-types": "^3.0.2",
    "typescript": "^5.9.0-beta"
  }
}
