{
  "name": "server",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "prepare:native-deps": "node ../../scripts/ensure-node-better-sqlite3.mjs",
    "_dev": "bun run prepare:native-deps && tsx watch src/index.ts",
    "mcp": "bun run src/mcp-bridge.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint --max-warnings 0",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@fastify/multipart": "^9.0.3",
    "@fastify/websocket": "^11.2.0",
    "@kombuse/agent": "*",
    "@kombuse/core": "*",
    "@kombuse/mcp": "*",
    "@kombuse/persistence": "*",
    "@kombuse/services": "*",
    "@kombuse/types": "*",
    "@modelcontextprotocol/sdk": "^1.18.1",
    "better-sqlite3": "^12.6.2",
    "fastify": "^5.7.4",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@repo/eslint-config": "*",
    "@repo/typescript-config": "*",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.15.3",
    "@types/ws": "^8.18.1",
    "eslint": "^9.39.1",
    "tsx": "^4.19.2",
    "typescript": "5.9.2",
    "vitest": "^3.0.0"
  },
  "trustedDependencies": ["better-sqlite3"]
}
