    "@kombuse/types": "*",
    "@modelcontextprotocol/sdk": "^1.18.1",
    "fastify": "^5.7.4",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@repo/eslint-config": "*",
    "@repo/typescript-config": "*",
    "@types/node": "^22.15.3",
    "@types/ws": "^8.18.1",
    "eslint": "^9.39.1",
    "tsx": "^4.19.2",
    "typescript": "5.9.2"
  },
